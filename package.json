{
  "name": "@trevonistrevon/pi-loop",
  "version": "0.5.5",
  "description": "A pi extension for cron/event-based agent re-wake loops and background process monitoring.",
  "author": "trevonistrevon",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/trvon/pi-loop.git"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "loop",
    "cron",
    "monitor",
    "scheduler"
  ],
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "^0.75.5",
    "@earendil-works/pi-tui": "^0.75.5"
  },
  "dependencies": {
    "typebox": "^1.1.34"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test && npm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "test:e2e": "bash test/e2e/reminder-injection.sh",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/ test/",
    "lint:fix": "biome check --fix src/ test/"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/node": "^25.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "typescript": "^6.0.0",
    "vitest": "^4.1.5"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  }
}
